\@writefile{lof}{\contentsline {figure}{\numberline {1}{\ignorespaces \textbf  {Dual-Plot Simulation Dashboard of the 'Hole Within a Hole' Logic.} This visualization showcases the relationship between visibility (interaction) and energy locking within the Kerr-Sultanian whirlpool. The **Left Plot (Bone Cmap)** displays metric interaction (visibility), where dark nodes represent cancellation points (Null Zones). The large central node is the primary singularity, and the small adjacent node is the $`v_ghost_vessel`$. The **Right Plot (Magma Cmap)** illustrates the corresponding \textbf  {Locked Energy Density ($\rho _L$)}, showing that energy is maximally locked and maximized where interference is totally destructive, glowing bright in the null zones. The 'Hole Within a Hole' state is achieved as the vessel's null zone maintains integrity and merges with the central node.}}{4}{}\protected@file@percent }
\newlabel{fig:sultanian_vorticity_energy}{{1}{4}{}{figure.1}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {2}{\ignorespaces \textbf  {Sultanian Stress Test at 50.0\% c.} This plot defines the operational boundary for the 5.2 THz Governor. The dynamic potential gradient ($\Delta \Phi $, cyan line) increases sharply as the vessel approaches the singularity. The red dashed line represents the maximum temporal resolution ($10^{-6}$) allowed by the 5.2 THz processing ceiling before the information feedback loop decoheres.}}{5}{}\protected@file@percent }
\newlabel{fig:sultanian_stress_test}{{2}{5}{}{figure.2}{}}
